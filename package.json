{
  "name": "event-planning",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "svelte-kit sync && vite build",
    "pages:deploy": "wrangler pages deploy .svelte-kit/cloudflare --project-name ${CLOUDFLARE_PROJECT_NAME:-event-planning}",
    "workers:deploy": "wrangler deploy",
    "deploy:pages": "npm run build && npm run pages:deploy",
    "deploy:workers": "npm run build && npm run workers:deploy",
    "db:migrate:remote": "wrangler d1 migrations apply event-planning --remote",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.0.7",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@types/node": "^22.15.30",
    "svelte": "^5.33.0",
    "svelte-check": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.2",
    "wrangler": "^4.19.1"
  }
}
